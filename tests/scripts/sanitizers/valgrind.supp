}
{
   openmpi_cond
   Memcheck:Cond
   ...
   obj:*libopen-pal*
}

# --- hwloc (MPI dependency) ---
{
   hwloc_topology_init
   Memcheck:Leak
   ...
   fun:hwloc_topology_init
}
{
   hwloc_bitmap_alloc
   Memcheck:Leak
   ...
   fun:hwloc_bitmap_alloc
}

# --- pthread internals ---
{
   pthread_once
   Memcheck:Leak
   ...
   fun:__pthread_once_slow
}

# --- GDR API (gdrcopy) ---
{
   gdr_open_ioctl
   Memcheck:Param
   ioctl(generic)
   ...
   fun:gdr_open
}
{
   gdr_map_cond
   Memcheck:Cond
   ...
   fun:gdr_map_v2
}
{
   gdr_map_value
   Memcheck:Value8
   ...
   fun:gdr_map_v2
}
{
   gdr_unmap_cond
   Memcheck:Cond
   ...
   fun:gdr_unmap
}
{
   gdr_unmap_value
   Memcheck:Value8
   ...
   fun:gdr_unmap
}

# --- OpenMPI TCP BTL uninitialized send ---
{
   openmpi_btl_tcp_send
   Memcheck:Param
   socketcall.sendto(msg)
   ...
   fun:mca_btl_tcp_send_blocking
}
